  create  table "sales_db"."analytics"."mart_sales_daily__dbt_tmp"
  
  
    as
  
  (
    

SELECT
    sale_date,
    SUM(total_sales) AS daily_revenue,
    SUM(num_transactions) AS daily_transactions,
    ROUND(AVG(avg_unit_price), 2) AS avg_price,
